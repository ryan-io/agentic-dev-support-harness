#!/bin/bash
# Pre-commit hook: run sync and validation on every commit.
# Output is formatted to be readable in both terminal output and the
# GitKraken commit panel (which displays stdout/stderr from the hook).
#
# Installation:
#   git config core.hooksPath .github/hooks
# (handled automatically by python .github/scripts/setup/repository-setup.py)
#
# Notes for GitKraken users:
#   - GitKraken Desktop surfaces this hook's echo output in the commit dialog.
#   - On macOS/Linux this file must be executable (chmod +x .github/hooks/pre-commit).
#   - Any non-zero exit code blocks the commit; fix the reported issue and retry.
#
# Notes for CLI users:
#   - Works the same way from any shell that runs POSIX scripts (Git Bash on
#     Windows, zsh/bash on macOS/Linux).
#   - To bypass intentionally: git commit --no-verify (or "Commit and skip
#     hooks" in GitKraken's commit panel).

set -e

# Resolve repo root so the hook works regardless of where git invokes it from.
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Pick the python executable that's available. Git Bash on Windows usually
# only has 'python'; macOS/Linux usually have 'python3'.
if command -v python3 >/dev/null 2>&1; then
    PYTHON=python3
elif command -v python >/dev/null 2>&1; then
    PYTHON=python
else
    echo "[pre-commit] ERROR: python not found on PATH. Install Python 3 and retry." >&2
    exit 1
fi

echo ""
echo "===================================================="
echo " [pre-commit] sync + validate"
echo "===================================================="

# --- 1. Sync (skipped when sources, mirrors, and sync script are unchanged) ---
# The hash covers the instruction sources and hub, the generated mirrors
# (.claude/rules/, CLAUDE.md), and the sync script itself (audit G4). A
# hand-edited mirror or a changed sync script invalidates the hash, sync
# reruns, and the regeneration overwrites the drift.
HASH_FILE=".claude/.sync-hash"

compute_sync_hash() {
    if command -v md5sum >/dev/null 2>&1; then
        SRC_HASH=$(find .github/instructions -name "*.instructions.md" -exec md5sum {} + 2>/dev/null | sort | md5sum | cut -d' ' -f1)
        HUB_HASH=$(md5sum .github/copilot-instructions.md 2>/dev/null | cut -d' ' -f1)
        MIRROR_HASH=$(find .claude/rules -name "*.md" -exec md5sum {} + 2>/dev/null | sort | md5sum | cut -d' ' -f1)
        EXTRA_HASH=$(md5sum CLAUDE.md .github/scripts/sync-claude-rules.py 2>/dev/null | sort | md5sum | cut -d' ' -f1)
        echo "${SRC_HASH}-${HUB_HASH}-${MIRROR_HASH}-${EXTRA_HASH}"
    elif command -v md5 >/dev/null 2>&1; then
        SRC_HASH=$(find .github/instructions -name "*.instructions.md" -exec md5 -q {} + 2>/dev/null | sort | md5 -q)
        HUB_HASH=$(md5 -q .github/copilot-instructions.md 2>/dev/null)
        MIRROR_HASH=$(find .claude/rules -name "*.md" -exec md5 -q {} + 2>/dev/null | sort | md5 -q)
        EXTRA_HASH=$( (md5 -q CLAUDE.md .github/scripts/sync-claude-rules.py 2>/dev/null) | sort | md5 -q)
        echo "${SRC_HASH}-${HUB_HASH}-${MIRROR_HASH}-${EXTRA_HASH}"
    fi
}

CURRENT_HASH=$(compute_sync_hash)

STORED_HASH=""
if [ -f "$HASH_FILE" ]; then
    STORED_HASH=$(cat "$HASH_FILE" 2>/dev/null)
fi

if [ -n "$CURRENT_HASH" ] && [ "$CURRENT_HASH" = "$STORED_HASH" ]; then
    echo ""
    echo "[1/2] Sync skipped (sources, mirrors, and sync script unchanged)"
else
    echo ""
    echo "[1/2] Syncing copilot-instructions.md and .github/instructions/ -> CLAUDE.md and .claude/rules/"
    echo "----------------------------------------------------"
    if ! $PYTHON .github/scripts/sync-claude-rules.py; then
        echo ""
        echo "[pre-commit] FAILED: sync errored. Fix the reported issue and retry." >&2
        exit 1
    fi

    # Stage any files the sync just regenerated so the commit captures them.
    git add CLAUDE.md .claude/rules/ 2>/dev/null || true

    # Store the post-sync hash (mirrors may have just changed) for next run.
    CURRENT_HASH=$(compute_sync_hash)
    if [ -n "$CURRENT_HASH" ]; then
        mkdir -p "$(dirname "$HASH_FILE")"
        echo "$CURRENT_HASH" > "$HASH_FILE"
    fi
fi

# --- 2. Validate (incremental when possible) ---
CHANGED_FILES=$(git diff --cached --name-only 2>/dev/null)
echo ""
if [ -n "$CHANGED_FILES" ]; then
    echo "[2/2] Validating (incremental -- only sections affected by staged files)"
    echo "----------------------------------------------------"
    # Split on newlines only and disable globbing so paths with spaces or
    # glob characters pass through intact; subshell keeps IFS/set local.
    if ! (
        IFS=$'\n'; set -f
        # shellcheck disable=SC2086
        $PYTHON .github/scripts/validate-system.py --changed $CHANGED_FILES
    ); then
        echo ""
        echo "[pre-commit] FAILED: validation reported issues above. Fix them and retry." >&2
        echo "             To bypass intentionally: git commit --no-verify" >&2
        exit 1
    fi
else
    echo "[2/2] Validating system invariants (full)"
    echo "----------------------------------------------------"
    if ! $PYTHON .github/scripts/validate-system.py; then
        echo ""
        echo "[pre-commit] FAILED: validation reported issues above. Fix them and retry." >&2
        echo "             To bypass intentionally: git commit --no-verify" >&2
        exit 1
    fi
fi

echo ""
echo "===================================================="
echo " [pre-commit] OK -- proceeding with commit"
echo "===================================================="
echo ""
