{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": ["build", "${workspaceFolder}/ProjectName.slnx"],
            "problemMatcher": "$msCompile",
            "group": { "kind": "build", "isDefault": true }
        },
        {
            "label": "test",
            "command": "dotnet",
            "type": "process",
            "args": ["test", "${workspaceFolder}/ProjectName.slnx"],
            "problemMatcher": "$msCompile",
            "group": "test"
        }
    ]
}
